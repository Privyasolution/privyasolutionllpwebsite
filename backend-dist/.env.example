# Copy this file to .env and fill in your values
# NEVER commit .env to version control

PORT=5000

# Google Workspace SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sales@privyasolution.com
SMTP_PASSWORD=your_google_app_password_here

# Recipient for contact inquiries
CONTACT_RECIPIENT=sales@privyasolution.com

# Allowed frontend origin (comma-separated for multiple)
FRONTEND_URL=https://privyasolution.com
